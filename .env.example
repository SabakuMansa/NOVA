# Gabarit de configuration — copiez ce fichier en .env.local et remplissez.
# .env.local n'est JAMAIS commité (voir .gitignore).

# --- Module Commande & Livraison ---
# "demo" (par défaut, données factices) ou "live" (vrai fournisseur de coursiers).
DELIVERY_MODE=demo

# Nécessaire UNIQUEMENT en mode live (fournis par le compte du commerçant après
# onboarding — voir README-delivery.md). Laisser vide en mode demo.
UBER_DIRECT_CUSTOMER_ID=
UBER_DIRECT_CLIENT_ID=
UBER_DIRECT_CLIENT_SECRET=
