# Gabarit de configuration — copiez ce fichier en .env.local et remplissez.
# .env.local n'est JAMAIS commité (voir .gitignore).

# --- Module Commande & Livraison ---
# "demo" (par défaut, données factices) ou "live" (vrai fournisseur de coursiers).
DELIVERY_MODE=demo

# Nécessaire UNIQUEMENT en mode live (fournis par le compte du commerçant après
# onboarding — voir README-delivery.md). Laisser vide en mode demo.
UBER_DIRECT_CUSTOMER_ID=
UBER_DIRECT_CLIENT_ID=
UBER_DIRECT_CLIENT_SECRET=

# --- Module Relance avis Google ---
# "demo" (par défaut, aucun envoi réel, simulation loggée) ou "live" (Resend).
EMAIL_MODE=demo

# Délai par défaut avant la relance, en heures (surchargé par commerce dans
# lib/reviews/businesses.ts si besoin). Défaut si absent : 3.
REVIEW_REQUEST_DELAY_HOURS=3

# Nécessaire UNIQUEMENT en mode live — voir README-reviews.md (domaine
# vérifié requis auprès de Resend). Laisser vide en mode demo.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Persistance des jobs planifiés : "memory" (défaut, dev uniquement) ou
# "supabase" (nécessaire dès qu'on quitte le poste de développement).
REVIEWS_STORE_MODE=memory
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Utilisé pour construire le lien de désinscription dans l'email. Laisser
# vide en dev (un domaine d'exemple est utilisé par défaut).
SITE_URL=

# --- Module Boutique (paiement Stripe, page /exemples/boutique) ---
# "test" (par défaut) ou "live". Une clé sk_test_… avec PAYMENT_MODE=live
# est refusée par la route de paiement (garde-fou).
PAYMENT_MODE=test

# Sans clé configurée, la route de paiement répond en mode démo (aucun
# appel Stripe réel) — la page reste démontrable sans compte Stripe.
# Carte de test : 4242 4242 4242 4242, n'importe quelle date future/CVC.
STRIPE_SECRET_KEY=
