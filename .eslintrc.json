{
  "extends": "next/core-web-vitals",
  "plugins": ["@typescript-eslint"],
  "ignorePatterns": ["app/_archive/**", "app/labo/**", "components/labo/**"],
  "rules": {
    "no-unused-vars": "off",
    "@typescript-eslint/no-unused-vars": [
      "warn",
      { "argsIgnorePattern": "^_" }
    ],
    "react/no-unescaped-entities": "off"
  }
}
